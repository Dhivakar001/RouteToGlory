rules_version = '2';

// RouteToGlory Firebase Storage Security Rules
// Deploy via: firebase deploy --only storage
// Or copy-paste into the Firebase Console → Storage → Rules tab

service firebase.storage {
  match /b/{bucket}/o {

    // ─── Player Images ──────────────────────
    // Only authenticated users can read player images
    // Only admins can upload (enforced via Firestore role check)
    // Max 2MB, images only
    match /players/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 2 * 1024 * 1024 // 2MB max
        && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    // ─── User Avatars ───────────────────────
    // Users can upload their own avatar
    match /avatars/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 1 * 1024 * 1024 // 1MB max
        && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    // ─── Deny everything else ───────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
